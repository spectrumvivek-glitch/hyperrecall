rules_version = '2';

// ─── Recallify — Firestore Security Rules ─────────────────────────────────────
//
// Schema:
//   users/{uid}                — profile doc
//   users/{uid}/data/{docId}   — combined meta (categories + plans + stats)
//   users/{uid}/notes/{noteId} — individual notes
//
// All data is scoped under the owner's UID.
//
// Deploy with:
//   firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ─── User profile ─────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // ─── Combined meta (categories, plans, stats) ────────────────────────
      match /data/{docId} {
        allow read, write: if isOwner(userId);
      }

      // ─── Notes ───────────────────────────────────────────────────────────
      match /notes/{noteId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Deny all other paths by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
